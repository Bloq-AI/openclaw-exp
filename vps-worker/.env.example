SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
WORKER_ID=worker-1
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
X_BEARER_TOKEN=your-x-bearer-token
# Optional: GitHub token for higher rate limits (not required for public repos)
# GITHUB_TOKEN=ghp_your-token
# Control plane — enables the worker to call the heartbeat every 5 min so
# triggers evaluate automatically. Both values must be set.
CONTROL_PLANE_URL=https://your-web-admin-url.vercel.app
OPS_KEY=your-ops-key
